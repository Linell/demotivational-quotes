## Local development only.
## Copy to `.dev.vars` (or set in your shell) when running locally.

# Run Inngest SDK in dev mode locally.
INNGEST_DEV=1

# Required for quote generation.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Required for production Inngest Cloud integration.
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
